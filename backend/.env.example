# ================================
# MI APP - Backend Environment
# ================================

# Server
PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=miapp_db
DB_USER=miapp_user
DB_PASSWORD=supersecret_change_in_prod

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_prod
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS (mobile origin, separated by comma)
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081

# Plans limits
FREE_PLAN_MAX_PRODUCTS=100
